---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ScreenshotMockup from '../components/ScreenshotMockup.astro';
---
<Layout title="Dromos — Triathlon Training Plans">
  <Header />

  <!-- Hero (dark) -->
  <section class="bg-[#111827] text-white px-6 pt-20 pb-16">
    <div class="max-w-5xl mx-auto flex flex-col lg:flex-row items-center gap-12">

      <!-- Left: copy -->
      <div class="flex-1 text-center lg:text-left">
        <div class="flex justify-center lg:justify-start mb-6">
          <picture>
            <source srcset="/assets/appicon-200.webp" type="image/webp" />
            <img src="/assets/appicon.png" alt="Dromos" class="w-16 h-16 rounded-2xl shadow-lg" width="64" height="64" />
          </picture>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight max-w-xl mx-auto lg:mx-0">
          You have 10 hours a week and one triathlon to get right.<br class="hidden sm:block" />
          <span class="text-amber-400">Waste nothing.</span>
        </h1>
        <p class="mt-6 text-lg text-gray-300 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          AI-powered triathlon training plans — from Sprint to Ironman.
          Personalized to your race, your fitness, your schedule. Free.
        </p>
        <div class="mt-8 flex justify-center lg:justify-start">
          <a
            href="#"
            class="inline-flex items-center gap-3 bg-amber-500 hover:bg-amber-400 text-black font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            Download on the App Store
          </a>
        </div>
      </div>

      <!-- Right: screenshot -->
      <div class="flex-shrink-0">
        <ScreenshotMockup src="/assets/screenshot-coach.png" alt="Dromos session with Strava data and coach feedback" />
      </div>

    </div>
  </section>

  <!-- Race distances strip -->
  <section class="bg-gray-900 text-gray-400 text-sm py-4 text-center tracking-wide">
    From Sprint to Ironman &nbsp;·&nbsp; Swim &nbsp;·&nbsp; Bike &nbsp;·&nbsp; Run &nbsp;·&nbsp; Strava sync &nbsp;·&nbsp; Free
  </section>

  <!-- Outcome cards -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <FeatureCard
          icon="🤖"
          headline="Other apps sell templates. Dromos builds your plan from scratch."
          body="From your FTP, VMA, CSS, race date, and weekly hours. Not a template. Not a generic block. Your plan."
          screenshotSrc="/assets/screenshot-plan.png"
          screenshotAlt="Dromos calendar view showing a personalized training week"
          isLead={true}
        />
        <FeatureCard
          icon="📊"
          headline="See exactly how you trained vs. the plan."
          body="Dromos auto-matches your Strava activities and shows where you're on track — or drifting."
          screenshotSrc="/assets/screenshot-session.png"
          screenshotAlt="Dromos home feed with session cards and intensity graphs"
        />
        <FeatureCard
          icon="💡"
          headline="Every session tells you why it's there."
          body="Coaching notes for every workout. Know the purpose, trust the process."
          screenshotSrc="/assets/screenshot-coach.png"
          screenshotAlt="Dromos session detail with coaching feedback"
        />
      </div>

      <!-- Strava badge -->
      <div class="mt-10 flex justify-center items-center gap-4">
        <img src="/assets/strava-compatible.svg" alt="Compatible with Strava" class="h-7" />
      </div>
    </div>
  </section>

  <!-- Credibility line -->
  <section class="py-12 text-center px-6">
    <p class="text-gray-500 text-sm max-w-md mx-auto leading-relaxed">
      Built by a triathlete preparing for Nîmes–Alpe d'Huez.<br />
      Every feature exists because I needed it.
    </p>
  </section>

  <Footer />
</Layout>
