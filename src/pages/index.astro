---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Dromos — 70.3 Training Plans Built for You">
  <Header />

  <main>
    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-6 pt-20 pb-16 text-center">
      <div class="flex justify-center mb-8">
        <img src="/assets/appicon.png" alt="Dromos app icon" class="w-20 h-20 rounded-2xl shadow-lg" />
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 leading-tight max-w-3xl mx-auto">
        You have 10 hours a week and one shot at the finish line.<br class="hidden sm:block" /> Waste nothing.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        A personalized 70.3 training plan built around your FTP, VMA, and race goal — with coaching notes that explain why every session is there.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-black text-white px-6 py-3 rounded-xl font-medium hover:bg-gray-800 transition-colors"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download on the App Store
        </a>
      </div>

      <!-- Screenshot placeholder -->
      <div class="mt-16 max-w-xs mx-auto">
        <div class="bg-gray-100 rounded-3xl aspect-[9/19.5] flex items-center justify-center border border-gray-200">
          <p class="text-gray-400 text-sm text-center px-4">App screenshot<br/>coming soon</p>
        </div>
      </div>
    </section>

    <!-- Outcome cards -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="text-3xl mb-4">🎯</div>
            <h2 class="text-lg font-bold text-gray-900 mb-3">A plan built for YOUR race, YOUR fitness, YOUR schedule.</h2>
            <p class="text-gray-600 text-sm leading-relaxed">Built from your FTP, VMA, and race goal. Not a template — a plan.</p>
          </div>

          <!-- Card 2 -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="text-3xl mb-4">📊</div>
            <h2 class="text-lg font-bold text-gray-900 mb-3">Train. Sync. See what you actually did vs. what was planned.</h2>
            <p class="text-gray-600 text-sm leading-relaxed">Dromos connects to Strava and matches your workouts automatically.</p>
          </div>

          <!-- Card 3 — key differentiator -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border-2 border-brand">
            <div class="text-3xl mb-4">💡</div>
            <h2 class="text-lg font-bold text-gray-900 mb-3">Every session explains WHY it's there — not just what to do.</h2>
            <p class="text-gray-600 text-sm leading-relaxed">Coaching notes for every workout. Know the purpose, trust the process.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Strava row -->
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-center gap-6 text-center sm:text-left">
        <p class="text-lg font-medium text-gray-700">Syncs with Strava.</p>
        <img src="/assets/strava-compatible.svg" alt="Compatible with Strava" class="h-8" />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
