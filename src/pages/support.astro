---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    q: "How do I get started?",
    a: "Download Dromos from the App Store, create an account, and complete the onboarding. You'll enter your race goal, performance metrics (FTP, VMA, CSS), and weekly availability. Dromos will generate a personalized 70.3 training plan in about 2 minutes."
  },
  {
    q: "How is my training plan generated?",
    a: "Your plan is generated by an AI model on our servers using your race goal, target date, performance metrics, and weekly availability. The model produces a periodized plan with Base, Build, Peak, and Taper phases — each session tailored to your fitness level, with coaching notes explaining the purpose of the workout."
  },
  {
    q: "How does Strava sync work?",
    a: "Connect your Strava account from the Profile screen. Once connected, Dromos syncs your recent activities and automatically matches them to planned sessions. Completed sessions show actual metrics (duration, distance, power or pace, heart rate) alongside your plan."
  },
  {
    q: "Can I modify my training plan?",
    a: "You can reorder sessions within a week using edit mode on the Home screen. Full plan adjustments (changing intensity, adding/removing sessions) are on the roadmap for a future release."
  },
  {
    q: "What data does Dromos store?",
    a: "Dromos stores your account email, training profile (goals, performance metrics, availability), your generated training plan, and Strava activities if you connect Strava. We do not sell or share your data. See our Privacy Policy for full details."
  },
  {
    q: "How do I delete my account?",
    a: "To delete your account and all associated data, email us at support@getdromos.com with the subject line \"Delete my account\". We will permanently delete your profile, training plan, and all associated data within 30 days."
  },
];
---
<Layout title="Support — Dromos" description="Support and FAQ for the Dromos triathlon training app.">
  <Header />

  <main class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Support</h1>
    <p class="text-gray-500 mb-12">Answers to common questions about Dromos.</p>

    <div class="space-y-8">
      {faqs.map((faq) => (
        <div class="border-b border-gray-100 pb-8">
          <h2 class="text-base font-semibold text-gray-900 mb-2">{faq.q}</h2>
          <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 bg-gray-50 rounded-2xl p-8">
      <h2 class="text-base font-semibold text-gray-900 mb-2">Still have a question?</h2>
      <p class="text-gray-600 text-sm mb-4">We're happy to help.</p>
      <a href="mailto:support@getdromos.com" class="inline-flex items-center gap-2 bg-brand text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
        Email support@getdromos.com
      </a>
    </div>

    <div class="mt-8 text-center">
      <a href="/" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">← Back to home</a>
    </div>
  </main>

  <Footer />
</Layout>
