---
interface Props {
  icon: string;
  headline: string;
  body: string;
  screenshotSrc?: string;
  screenshotAlt?: string;
  isLead?: boolean;
}
const { icon, headline, body, screenshotSrc, screenshotAlt = "", isLead = false } = Astro.props;
---
<div class:list={["bg-white rounded-2xl p-8 shadow-sm border flex flex-col gap-6", isLead ? "border-2 border-brand" : "border-gray-100"]}>
  <div class="text-3xl">{icon}</div>
  <div>
    <h2 class="text-lg font-bold text-gray-900 mb-3">{headline}</h2>
    <p class="text-gray-600 text-sm leading-relaxed">{body}</p>
  </div>
  {screenshotSrc && (
    <div class="mt-2">
      <img
        src={screenshotSrc}
        alt={screenshotAlt}
        class="w-full rounded-xl shadow-md border border-gray-100"
        loading="lazy"
      />
    </div>
  )}
</div>
